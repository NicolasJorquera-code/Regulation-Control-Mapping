"""Control Builder — The Executive Wizard.

A standalone tab for building a DomainConfig from scratch via a 6-step
guided wizard. Enhanced with template gallery, section import, AI assists,
card-based layouts, plotly charts, and config quality scoring.

Extracted from config_wizard.py and significantly enhanced for the
frontend redesign.
"""

from __future__ import annotations

import asyncio
import copy
import logging
import re
from typing import Any

import streamlit as st
import yaml

from controlnexus.core.domain_config import DomainConfig

logger = logging.getLogger(__name__)

TOTAL_STEPS = 6
STEP_LABELS = [
    "Basics",
    "Control Types",
    "Business Units",
    "Process Areas",
    "Narrative & Quality",
    "Review & Export",
]

_DEFAULT_PLACEMENTS = ["Preventive", "Detective", "Contingency Planning"]
_DEFAULT_METHODS = ["Automated", "Manual", "Automated with Manual Component"]
_DEFAULT_FREQUENCY_TIERS = [
    {"label": "Daily", "rank": 1, "keywords": ["daily", "every day", "eod"]},
    {"label": "Weekly", "rank": 2, "keywords": ["weekly", "every week"]},
    {"label": "Monthly", "rank": 3, "keywords": ["monthly", "every month", "month-end"]},
    {"label": "Quarterly", "rank": 4, "keywords": ["quarterly", "every quarter"]},
    {"label": "Semi-Annual", "rank": 5, "keywords": ["semi-annual", "twice a year"]},
    {"label": "Annual", "rank": 6, "keywords": ["annual", "annually", "yearly"]},
]
_DEFAULT_QUALITY_RATINGS = ["Strong", "Effective", "Satisfactory", "Needs Improvement"]
_DEFAULT_NARRATIVE_FIELDS = [
    {"name": "who", "definition": "The specific role responsible for performing the control", "required": True},
    {"name": "what", "definition": "The specific action performed", "required": True},
    {"name": "when", "definition": "The timing or trigger for the control", "required": True},
    {"name": "where", "definition": "The system or location where the control is performed", "required": True},
    {"name": "why", "definition": "The risk or objective the control addresses", "required": True},
    {"name": "full_description", "definition": "Prose narrative incorporating all fields", "required": True},
]
_AFFINITY_LEVELS = ["HIGH", "MEDIUM", "LOW", "NONE"]

_INDUSTRY_OPTIONS = ["Banking", "Insurance", "Healthcare", "Technology", "Generic"]
_JURISDICTION_OPTIONS = ["US Federal Banking", "US State Banking", "EU", "UK", "Generic"]


# ── Session state helpers ─────────────────────────────────────────────────────


def _get_form() -> dict[str, Any]:
    """Return the builder form data dict, initialising if needed."""
    if "builder_form" not in st.session_state:
        st.session_state["builder_form"] = _blank_form()
    return st.session_state["builder_form"]


def _blank_form() -> dict[str, Any]:
    return {
        "name": "",
        "description": "",
        "industry": "Generic",
        "jurisdiction": "Generic",
        "control_types": [],
        "business_units": [],
        "process_areas": [],
        "placements": [{"name": p, "description": ""} for p in _DEFAULT_PLACEMENTS],
        "methods": [{"name": m, "description": ""} for m in _DEFAULT_METHODS],
        "frequency_tiers": list(_DEFAULT_FREQUENCY_TIERS),
        "quality_ratings": list(_DEFAULT_QUALITY_RATINGS),
        "narrative": {
            "fields": list(_DEFAULT_NARRATIVE_FIELDS),
            "word_count_min": 30,
            "word_count_max": 80,
        },
    }


def _get_step() -> int:
    return st.session_state.get("builder_step", 0)  # 0 = starting point


def _set_step(step: int) -> None:
    st.session_state["builder_step"] = max(0, min(step, TOTAL_STEPS))


def _push_undo() -> None:
    """Push current form state to undo stack before destructive action."""
    history = st.session_state.get("builder_history", [])
    history.append(copy.deepcopy(st.session_state.get("builder_form", {})))
    if len(history) > 20:
        history = history[-20:]
    st.session_state["builder_history"] = history


def _pop_undo() -> None:
    """Restore last form state."""
    history = st.session_state.get("builder_history", [])
    if history:
        st.session_state["builder_form"] = history.pop()
        st.session_state["builder_history"] = history
        st.rerun()


def _auto_code(name: str) -> str:
    consonants = re.sub(r"[aeiouAEIOU\s\-,]", "", name)
    return consonants[:3].upper() or "UNK"


# ── LLM helpers ───────────────────────────────────────────────────────────────


def _run_section_autofill(section_name: str, control_type_names: list[str], config_context: dict) -> dict[str, Any]:
    from controlnexus.agents.base import AgentContext
    from controlnexus.agents.config_proposer import ConfigProposerAgent
    from controlnexus.core.transport import build_client_from_env

    client = build_client_from_env()
    ctx = AgentContext(client=client, model=client.model if client else "none", temperature=0.2, max_tokens=2048, timeout_seconds=120)
    agent = ConfigProposerAgent(ctx, name="ConfigProposer-Section")
    result = asyncio.run(agent.execute(mode="section_autofill", section_name=section_name, control_type_names=control_type_names, config_context=config_context))
    if client is not None:
        asyncio.run(client.close())
    return result


def _run_enrich(type_names: list[str]) -> dict[str, Any]:
    from controlnexus.agents.base import AgentContext
    from controlnexus.agents.config_proposer import ConfigProposerAgent
    from controlnexus.core.transport import build_client_from_env

    client = build_client_from_env()
    ctx = AgentContext(client=client, model=client.model if client else "none", temperature=0.2, max_tokens=2048, timeout_seconds=120)
    agent = ConfigProposerAgent(ctx, name="ConfigProposer-Enrich")
    result = asyncio.run(agent.execute(mode="enrich", type_names=type_names))
    if client is not None:
        asyncio.run(client.close())
    return result


# ── Sidebar ───────────────────────────────────────────────────────────────────


def _render_sidebar(current_step: int) -> None:
    """Render step progress sidebar with config quality score."""
    for i in range(1, TOTAL_STEPS + 1):
        if i < current_step:
            icon = "✅"
        elif i == current_step:
            icon = "●"
        else:
            icon = "○"

        label = f"{icon} Step {i}: {STEP_LABELS[i - 1]}"
        if i <= current_step:
            if st.button(label, key=f"cb_nav_{i}", use_container_width=True):
                _set_step(i)
                st.rerun()
        else:
            st.markdown(f"<div style='padding:6px 12px;color:#a8a8a8;'>{label}</div>", unsafe_allow_html=True)

    st.markdown("---")

    # Undo button
    history = st.session_state.get("builder_history", [])
    if history:
        if st.button("↩ Undo", key="cb_undo", use_container_width=True):
            _pop_undo()

    # Config quality score
    from controlnexus.ui.components.config_scorer import compute_config_score, render_config_score

    form = _get_form()
    score = compute_config_score(form)
    render_config_score(score)


# ── Starting Point ────────────────────────────────────────────────────────────


def _render_starting_point(form: dict[str, Any]) -> None:
    """Step 0: Choose how to start — Fresh, Template, or Excel Import."""
    st.markdown("#### How would you like to start?")

    col_fresh, col_template, col_excel = st.columns(3)

    with col_fresh:
        with st.container(border=True):
            st.markdown("**Start Fresh**")
            st.caption("Empty config — begin from scratch.")
            if st.button("Start Fresh", key="cb_start_fresh", use_container_width=True, type="primary"):
                st.session_state["builder_form"] = _blank_form()
                st.session_state["builder_starting_point"] = "fresh"
                _set_step(1)
                st.rerun()

    with col_template:
        with st.container(border=True):
            st.markdown("**From Template**")
            st.caption("Start with a pre-built profile and customize.")
            if st.button("Browse Templates", key="cb_start_template", use_container_width=True):
                st.session_state["_cb_show_templates"] = True
                st.rerun()

    with col_excel:
        with st.container(border=True):
            st.markdown("**Import from Excel**")
            st.caption("Upload an existing register and auto-generate a config.")
            if st.button("Import Excel", key="cb_start_excel", use_container_width=True):
                st.session_state["_cb_show_excel"] = True
                st.rerun()

    # Template gallery (expanded if clicked)
    if st.session_state.get("_cb_show_templates"):
        st.markdown("---")
        st.markdown("#### Select a Template")
        from controlnexus.ui.components.template_gallery import render_template_gallery

        template_data = render_template_gallery(key_prefix="cb_tpl")
        if template_data is not None:
            # Deep-copy template data into builder form
            new_form = _blank_form()
            for key in ("name", "description", "control_types", "business_units", "process_areas",
                        "placements", "methods", "frequency_tiers", "quality_ratings", "narrative"):
                if key in template_data:
                    new_form[key] = copy.deepcopy(template_data[key])
            st.session_state["builder_form"] = new_form
            st.session_state["builder_starting_point"] = f"template:{template_data.get('name', 'unknown')}"
            st.session_state.pop("_cb_show_templates", None)
            _set_step(1)
            st.rerun()

    # Excel import (expanded if clicked)
    if st.session_state.get("_cb_show_excel"):
        st.markdown("---")
        from controlnexus.ui.excel_import import render_excel_import

        excel_config = render_excel_import()
        if excel_config is not None:
            new_form = _blank_form()
            data = excel_config.model_dump()
            for key in ("name", "description", "control_types", "business_units", "process_areas",
                        "placements", "methods", "frequency_tiers", "quality_ratings", "narrative"):
                if key in data:
                    new_form[key] = copy.deepcopy(data[key])
            st.session_state["builder_form"] = new_form
            st.session_state["builder_starting_point"] = "excel"
            st.session_state.pop("_cb_show_excel", None)
            _set_step(1)
            st.rerun()


# ── Step 1: Basics ────────────────────────────────────────────────────────────


def _render_step_basics(form: dict[str, Any]) -> None:
    st.markdown("#### Step 1: Basics")
    st.caption("Name your configuration and provide context.")

    form["name"] = st.text_input(
        "Config Name",
        value=form.get("name", ""),
        placeholder="e.g. community-bank-demo",
        key="cb_name",
    )
    form["description"] = st.text_area(
        "Description",
        value=form.get("description", ""),
        placeholder="Brief description of the organization and control domain.",
        key="cb_desc",
        height=100,
    )

    c1, c2 = st.columns(2)
    with c1:
        current_industry = form.get("industry", "Generic")
        idx = _INDUSTRY_OPTIONS.index(current_industry) if current_industry in _INDUSTRY_OPTIONS else len(_INDUSTRY_OPTIONS) - 1
        form["industry"] = st.selectbox("Industry", options=_INDUSTRY_OPTIONS, index=idx, key="cb_industry")
    with c2:
        current_juris = form.get("jurisdiction", "Generic")
        idx = _JURISDICTION_OPTIONS.index(current_juris) if current_juris in _JURISDICTION_OPTIONS else len(_JURISDICTION_OPTIONS) - 1
        form["jurisdiction"] = st.selectbox("Regulatory Jurisdiction", options=_JURISDICTION_OPTIONS, index=idx, key="cb_jurisdiction")

    if st.button("Next →", type="primary", key="cb_step1_next"):
        if not form["name"].strip():
            st.error("Config name is required.")
        else:
            _set_step(2)
            st.rerun()


# ── Step 2: Control Types ────────────────────────────────────────────────────


def _render_step_control_types(form: dict[str, Any]) -> None:
    st.markdown("#### Step 2: Control Types")
    st.caption("Define the control types in your taxonomy. At least one is required.")

    types_list: list[dict[str, Any]] = form.setdefault("control_types", [])

    # Action buttons
    col_add, col_ai, col_import = st.columns(3)
    with col_add:
        if st.button("➕ Add Control Type", key="cb_add_ct"):
            types_list.append({
                "name": "", "definition": "", "code": "",
                "min_frequency_tier": None, "placement_categories": [], "evidence_criteria": [],
            })
            st.rerun()
    with col_ai:
        if st.button("🤖 Auto-fill Definitions", key="cb_enrich_ct"):
            names = [ct["name"] for ct in types_list if ct.get("name")]
            if names:
                _push_undo()
                with st.status("Enriching control types…", expanded=True) as status:
                    try:
                        enriched = _run_enrich(names)
                        enriched_types = {ct["name"]: ct for ct in enriched.get("control_types", [])}
                        for ct in types_list:
                            if ct["name"] in enriched_types:
                                enr = enriched_types[ct["name"]]
                                if not ct.get("definition"):
                                    ct["definition"] = enr.get("definition", "")
                                if not ct.get("code"):
                                    ct["code"] = enr.get("code", "")
                                if not ct.get("evidence_criteria"):
                                    ct["evidence_criteria"] = enr.get("evidence_criteria", [])
                                if ct.get("min_frequency_tier") is None:
                                    ct["min_frequency_tier"] = enr.get("min_frequency_tier")
                                if not ct.get("placement_categories"):
                                    ct["placement_categories"] = enr.get("placement_categories", [])
                        status.update(label="✅ Enrichment complete", state="complete")
                    except Exception as e:
                        status.update(label="❌ Enrichment failed", state="error")
                        st.error(str(e))
                st.rerun()
            else:
                st.warning("Add at least one control type name first.")
    with col_import:
        if st.button("📥 Import from Taxonomy", key="cb_import_ct"):
            st.session_state["_cb_show_type_import"] = not st.session_state.get("_cb_show_type_import", False)
            st.rerun()

    # Type import from existing profiles
    if st.session_state.get("_cb_show_type_import"):
        _render_type_import(types_list)

    # Card-based display
    placement_names = [p["name"] for p in form.get("placements", []) if isinstance(p, dict)] or _DEFAULT_PLACEMENTS
    freq_options = [None, "Daily", "Weekly", "Monthly", "Quarterly", "Semi-Annual", "Annual"]

    # Render as cards for display, use dialog for editing
    if types_list:
        from controlnexus.ui.components.config_cards import render_control_type_cards
        render_control_type_cards(types_list, on_edit="cb_ct_edit", on_remove="cb_ct_rm", columns=3)

        # Handle edit/remove button clicks
        to_remove = []
        for i in range(len(types_list)):
            if st.session_state.get(f"cb_ct_rm_{i}"):
                to_remove.append(i)
            if st.session_state.get(f"cb_ct_edit_{i}"):
                st.session_state["_cb_editing_ct"] = i

        if to_remove:
            _push_undo()
            for idx in reversed(to_remove):
                types_list.pop(idx)
            st.rerun()

    # Inline edit form for a single type
    editing_idx = st.session_state.get("_cb_editing_ct")
    if editing_idx is not None and 0 <= editing_idx < len(types_list):
        ct = types_list[editing_idx]
        with st.container(border=True):
            st.markdown(f"**Editing: {ct.get('name', '(unnamed)')}**")
            ct["name"] = st.text_input("Name", value=ct.get("name", ""), key="cb_ct_ed_name")
            ct["definition"] = st.text_area("Definition", value=ct.get("definition", ""), key="cb_ct_ed_def", height=80)
            c1, c2 = st.columns(2)
            with c1:
                ct["code"] = st.text_input("Code (3 letters)", value=ct.get("code", "") or _auto_code(ct.get("name", "")), max_chars=3, key="cb_ct_ed_code")
            with c2:
                current_freq = ct.get("min_frequency_tier")
                freq_idx = freq_options.index(current_freq) if current_freq in freq_options else 0
                ct["min_frequency_tier"] = st.selectbox("Min Frequency", options=freq_options, index=freq_idx, format_func=lambda x: x or "None", key="cb_ct_ed_freq")
            ct["placement_categories"] = st.multiselect("Placement Categories", options=placement_names, default=[p for p in ct.get("placement_categories", []) if p in placement_names], key="cb_ct_ed_place")
            evidence_text = "\n".join(ct.get("evidence_criteria", []))
            evidence_input = st.text_area("Evidence Criteria (one per line)", value=evidence_text, key="cb_ct_ed_evid", height=80)
            ct["evidence_criteria"] = [line.strip() for line in evidence_input.split("\n") if line.strip()]
            if st.button("Done Editing", key="cb_ct_ed_done"):
                st.session_state.pop("_cb_editing_ct", None)
                st.rerun()

    # Navigation
    col_back, col_next = st.columns(2)
    with col_back:
        if st.button("← Back", key="cb_step2_back"):
            _set_step(1)
            st.rerun()
    with col_next:
        if st.button("Next →", type="primary", key="cb_step2_next"):
            valid_types = [ct for ct in types_list if ct.get("name", "").strip()]
            if not valid_types:
                st.error("At least one control type with a name is required.")
            else:
                form["control_types"] = valid_types
                _set_step(3)
                st.rerun()


def _render_type_import(types_list: list[dict[str, Any]]) -> None:
    """Import control types from an existing profile."""
    from controlnexus.ui.components.template_gallery import _profiles_dir
    import yaml as _yaml

    profiles_path = _profiles_dir()
    yaml_files = sorted(profiles_path.glob("*.yaml")) if profiles_path.is_dir() else []
    if not yaml_files:
        st.info("No profiles available for import.")
        return

    selected_profile = st.selectbox(
        "Import types from profile",
        options=yaml_files,
        format_func=lambda p: p.stem.replace("_", " ").title(),
        key="cb_type_import_profile",
    )
    if selected_profile:
        data = _yaml.safe_load(selected_profile.read_text(encoding="utf-8"))
        available_types = data.get("control_types", [])
        existing_names = {ct["name"] for ct in types_list}
        importable = [ct for ct in available_types if ct.get("name") and ct["name"] not in existing_names]

        if importable:
            selected_names = st.multiselect(
                "Select types to import",
                options=[ct["name"] for ct in importable],
                key="cb_type_import_select",
            )
            if selected_names and st.button("Import Selected Types", key="cb_type_import_btn"):
                _push_undo()
                for ct in importable:
                    if ct["name"] in selected_names:
                        types_list.append(copy.deepcopy(ct))
                st.session_state["_cb_show_type_import"] = False
                st.rerun()
        else:
            st.info("All types from this profile are already in your config.")


# ── Step 3: Business Units ───────────────────────────────────────────────────


def _render_step_business_units(form: dict[str, Any]) -> None:
    st.markdown("#### Step 3: Business Units")
    st.caption("Define business units (optional). You can skip this step.")

    bu_list: list[dict[str, Any]] = form.setdefault("business_units", [])
    type_names = [ct["name"] for ct in form.get("control_types", []) if ct.get("name")]
    section_ids = [pa["id"] for pa in form.get("process_areas", []) if pa.get("id")]

    if st.button("➕ Add Business Unit", key="cb_add_bu"):
        next_num = len(bu_list) + 1
        bu_list.append({
            "id": f"BU-{next_num:03d}", "name": "", "description": "",
            "primary_sections": [], "key_control_types": [], "regulatory_exposure": [],
        })
        st.rerun()

    if not section_ids:
        st.info("💡 You'll define sections in Step 4. You can come back to link them.")

    # Card display
    if bu_list:
        from controlnexus.ui.components.config_cards import render_business_unit_cards
        render_business_unit_cards(bu_list, on_edit="cb_bu_edit", on_remove="cb_bu_rm")

        # Handle clicks
        to_remove = []
        for i in range(len(bu_list)):
            if st.session_state.get(f"cb_bu_rm_{i}"):
                to_remove.append(i)
            if st.session_state.get(f"cb_bu_edit_{i}"):
                st.session_state["_cb_editing_bu"] = i

        if to_remove:
            _push_undo()
            for idx in reversed(to_remove):
                bu_list.pop(idx)
            st.rerun()

    # Inline edit
    editing_idx = st.session_state.get("_cb_editing_bu")
    if editing_idx is not None and 0 <= editing_idx < len(bu_list):
        bu = bu_list[editing_idx]
        with st.container(border=True):
            st.markdown(f"**Editing: {bu.get('name', '(unnamed)')}**")
            c1, c2 = st.columns(2)
            with c1:
                bu["id"] = st.text_input("ID", value=bu.get("id", ""), key="cb_bu_ed_id")
            with c2:
                bu["name"] = st.text_input("Name", value=bu.get("name", ""), key="cb_bu_ed_name")
            bu["description"] = st.text_area("Description", value=bu.get("description", ""), key="cb_bu_ed_desc", height=60)
            if section_ids:
                bu["primary_sections"] = st.multiselect("Primary Sections", options=section_ids, default=[s for s in bu.get("primary_sections", []) if s in section_ids], key="cb_bu_ed_sec")
            else:
                sec_text = st.text_input("Primary Sections (comma-separated)", value=", ".join(bu.get("primary_sections", [])), key="cb_bu_ed_sec_txt")
                bu["primary_sections"] = [s.strip() for s in sec_text.split(",") if s.strip()]
            bu["key_control_types"] = st.multiselect("Key Control Types", options=type_names, default=[t for t in bu.get("key_control_types", []) if t in type_names], key="cb_bu_ed_types")
            reg_text = st.text_input("Regulatory Exposure (comma-separated)", value=", ".join(bu.get("regulatory_exposure", [])), key="cb_bu_ed_reg")
            bu["regulatory_exposure"] = [r.strip() for r in reg_text.split(",") if r.strip()]
            if st.button("Done Editing", key="cb_bu_ed_done"):
                st.session_state.pop("_cb_editing_bu", None)
                st.rerun()

    col_back, col_next = st.columns(2)
    with col_back:
        if st.button("← Back", key="cb_step3_back"):
            _set_step(2)
            st.rerun()
    with col_next:
        if st.button("Next →", type="primary", key="cb_step3_next"):
            form["business_units"] = bu_list
            _set_step(4)
            st.rerun()


# ── Step 4: Process Areas ────────────────────────────────────────────────────


def _render_step_process_areas(form: dict[str, Any]) -> None:
    st.markdown("#### Step 4: Process Areas")
    st.caption("Define sections with risk profiles, affinity grids, registries, and exemplars.")

    pa_list: list[dict[str, Any]] = form.setdefault("process_areas", [])
    type_names = [ct["name"] for ct in form.get("control_types", []) if ct.get("name")]
    placement_names = [p["name"] for p in form.get("placements", []) if isinstance(p, dict)] or _DEFAULT_PLACEMENTS
    method_names = [m["name"] for m in form.get("methods", []) if isinstance(m, dict)] or _DEFAULT_METHODS
    quality_options = form.get("quality_ratings", _DEFAULT_QUALITY_RATINGS)

    # Action bar
    col_add, col_import, col_suggest = st.columns(3)
    with col_add:
        if st.button("➕ Add Section", key="cb_add_pa"):
            next_id = f"{len(pa_list) + 1}.0"
            pa_list.append({
                "id": next_id, "name": "", "domain": "",
                "risk_profile": {"inherent_risk": 3, "regulatory_intensity": 3, "control_density": 3, "multiplier": 1.0, "rationale": ""},
                "affinity": {"HIGH": [], "MEDIUM": [], "LOW": [], "NONE": []},
                "registry": {"roles": [], "systems": [], "data_objects": [], "evidence_artifacts": [], "event_triggers": [], "regulatory_frameworks": []},
                "exemplars": [],
            })
            st.session_state["_cb_active_section"] = len(pa_list) - 1
            st.rerun()
    with col_import:
        if st.button("📥 Import Sections", key="cb_import_sections"):
            st.session_state["_cb_show_section_import"] = not st.session_state.get("_cb_show_section_import", False)
            st.rerun()
    with col_suggest:
        if st.button("🤖 Suggest Sections", key="cb_suggest_sections"):
            st.info("AI section suggestion coming soon — uses industry + description + existing types.")

    # Section import dialog
    if st.session_state.get("_cb_show_section_import"):
        from controlnexus.ui.components.section_import import render_section_import
        existing_ids = [pa["id"] for pa in pa_list]
        imported = render_section_import(existing_ids, key_prefix="cb_sec_imp")
        if imported:
            _push_undo()
            pa_list.extend(imported)
            st.session_state["_cb_show_section_import"] = False
            st.success(f"Imported {len(imported)} section(s)!")
            st.rerun()

    if not pa_list:
        st.info("No sections defined yet. Add one or import from YAML.")
        col_back, _ = st.columns(2)
        with col_back:
            if st.button("← Back", key="cb_step4_back_empty"):
                _set_step(3)
                st.rerun()
        return

    # Section navigator
    from controlnexus.ui.components.config_cards import render_section_pill_strip
    active_idx = st.session_state.get("_cb_active_section", 0)
    if active_idx >= len(pa_list):
        active_idx = 0
    new_idx = render_section_pill_strip(pa_list, active_idx, key_prefix="cb_secnav")
    if new_idx == -1:
        # Add new section
        next_id = f"{len(pa_list) + 1}.0"
        pa_list.append({
            "id": next_id, "name": "", "domain": "",
            "risk_profile": {"inherent_risk": 3, "regulatory_intensity": 3, "control_density": 3, "multiplier": 1.0, "rationale": ""},
            "affinity": {"HIGH": [], "MEDIUM": [], "LOW": [], "NONE": []},
            "registry": {"roles": [], "systems": [], "data_objects": [], "evidence_artifacts": [], "event_triggers": [], "regulatory_frameworks": []},
            "exemplars": [],
        })
        new_idx = len(pa_list) - 1
    st.session_state["_cb_active_section"] = new_idx
    pa = pa_list[new_idx]

    # Section header
    st.markdown(f"### Section {pa.get('id', '?')}: {pa.get('name', '(unnamed)')}")

    c1, c2, c3 = st.columns(3)
    with c1:
        pa["id"] = st.text_input("ID", value=pa.get("id", ""), key="cb_pa_id")
    with c2:
        pa["name"] = st.text_input("Name", value=pa.get("name", ""), key="cb_pa_name")
    with c3:
        auto_domain = re.sub(r"[^a-z0-9]+", "_", pa.get("name", "").lower()).strip("_")
        pa["domain"] = st.text_input("Domain", value=pa.get("domain", "") or auto_domain, key="cb_pa_domain")

    # AI auto-fill
    col_ai, col_rm = st.columns([3, 1])
    with col_ai:
        if st.button("🤖 AI Fill Section", key="cb_pa_ai"):
            if pa.get("name"):
                _push_undo()
                with st.status(f"Auto-filling '{pa['name']}'…", expanded=True) as status:
                    try:
                        result = _run_section_autofill(pa["name"], type_names, {"name": form.get("name", ""), "description": form.get("description", "")})
                        for k in ("risk_profile", "affinity", "registry", "exemplars"):
                            if k in result:
                                pa[k] = result[k]
                        status.update(label="✅ Auto-fill complete", state="complete")
                    except Exception as e:
                        status.update(label="❌ Auto-fill failed", state="error")
                        st.error(str(e))
                st.rerun()
            else:
                st.warning("Enter a section name first.")
    with col_rm:
        if st.button("🗑 Remove Section", key="cb_pa_rm"):
            _push_undo()
            pa_list.pop(new_idx)
            st.session_state["_cb_active_section"] = max(0, new_idx - 1)
            st.rerun()

    # Sub-tabs for section content
    sub_risk, sub_affinity, sub_registry, sub_exemplars = st.tabs(
        ["Risk Profile", "Affinity", "Registry", "Exemplars"]
    )

    with sub_risk:
        _render_section_risk_profile(pa, pa_list, new_idx)

    with sub_affinity:
        _render_section_affinity(pa, type_names, new_idx)

    with sub_registry:
        _render_section_registry(pa, new_idx)

    with sub_exemplars:
        _render_section_exemplars(pa, type_names, placement_names, method_names, quality_options, new_idx)

    # Navigation
    st.markdown("---")
    col_back, col_next = st.columns(2)
    with col_back:
        if st.button("← Back", key="cb_step4_back"):
            _set_step(3)
            st.rerun()
    with col_next:
        if st.button("Next →", type="primary", key="cb_step4_next"):
            form["process_areas"] = pa_list
            _set_step(5)
            st.rerun()


def _render_section_risk_profile(pa: dict, all_sections: list[dict], idx: int) -> None:
    """Risk profile sub-tab with radar chart and sliders."""
    rp = pa.setdefault("risk_profile", {"inherent_risk": 3, "regulatory_intensity": 3, "control_density": 3, "multiplier": 1.0, "rationale": ""})

    col_chart, col_sliders = st.columns([1, 1])

    with col_sliders:
        rp["inherent_risk"] = st.slider("Inherent Risk", 1, 5, rp.get("inherent_risk", 3), key=f"cb_rp_ir_{idx}")
        rp["regulatory_intensity"] = st.slider("Regulatory Intensity", 1, 5, rp.get("regulatory_intensity", 3), key=f"cb_rp_ri_{idx}")
        rp["control_density"] = st.slider("Control Density", 1, 5, rp.get("control_density", 3), key=f"cb_rp_cd_{idx}")
        rp["multiplier"] = st.number_input("Multiplier", min_value=0.1, max_value=5.0, value=float(rp.get("multiplier", 1.0)), step=0.1, key=f"cb_rp_mul_{idx}")

    with col_chart:
        from controlnexus.ui.components.charts import render_risk_radar
        render_risk_radar(rp, title=pa.get("name", ""), height=280)

    rp["rationale"] = st.text_area("Rationale", value=rp.get("rationale", ""), key=f"cb_rp_rat_{idx}", height=60)

    # Cross-section comparison: multiplier bars
    if len(all_sections) > 1:
        st.caption("Section multipliers comparison:")
        for j, s in enumerate(all_sections):
            m = s.get("risk_profile", {}).get("multiplier", 1.0)
            label = f"{s.get('id', '?')}"
            marker = " ◄" if j == idx else ""
            bar_width = min(m / 5.0 * 100, 100)
            color = "#0f62fe" if j == idx else "#e0e0e0"
            st.markdown(
                f'<div style="display:flex;align-items:center;gap:8px;margin:2px 0;">'
                f'<span style="width:30px;font-size:12px;">{label}</span>'
                f'<div style="background:{color};height:12px;width:{bar_width}%;border-radius:2px;"></div>'
                f'<span style="font-size:12px;">{m:.1f}x{marker}</span></div>',
                unsafe_allow_html=True,
            )


def _render_section_affinity(pa: dict, type_names: list[str], idx: int) -> None:
    """Affinity grid sub-tab."""
    if not type_names:
        st.info("Define control types in Step 2 first.")
        return

    from controlnexus.ui.components.affinity_grid import render_affinity_grid
    current_affinity = pa.get("affinity", {"HIGH": [], "MEDIUM": [], "LOW": [], "NONE": []})
    pa["affinity"] = render_affinity_grid(type_names, current_affinity, key_prefix=f"cb_aff_{idx}")


def _render_section_registry(pa: dict, idx: int) -> None:
    """Registry sub-tab with tag-style inputs."""
    registry = pa.setdefault("registry", {
        "roles": [], "systems": [], "data_objects": [],
        "evidence_artifacts": [], "event_triggers": [], "regulatory_frameworks": [],
    })

    from controlnexus.ui.components.config_cards import render_registry_tags

    fields = [
        ("roles", "Roles"), ("systems", "Systems"), ("data_objects", "Data Objects"),
        ("evidence_artifacts", "Evidence Artifacts"), ("event_triggers", "Event Triggers"),
        ("regulatory_frameworks", "Regulatory Frameworks"),
    ]
    cols = st.columns(2)
    for k, (field_key, label) in enumerate(fields):
        with cols[k % 2]:
            registry[field_key] = render_registry_tags(
                label, registry.get(field_key, []), key=f"cb_reg_{idx}_{field_key}"
            )


def _render_section_exemplars(
    pa: dict, type_names: list[str], placement_names: list[str],
    method_names: list[str], quality_options: list[str], idx: int,
) -> None:
    """Exemplars sub-tab with rich cards."""
    exemplars = pa.setdefault("exemplars", [])

    if st.button("➕ Add Exemplar", key=f"cb_add_ex_{idx}"):
        exemplars.append({
            "control_type": type_names[0] if type_names else "",
            "placement": placement_names[0] if placement_names else "Detective",
            "method": method_names[0] if method_names else "Manual",
            "full_description": "", "word_count": 0, "quality_rating": "Effective",
        })
        st.rerun()

    to_remove = []
    for ei, ex in enumerate(exemplars):
        with st.container(border=True):
            # Header
            st.markdown(
                f"**Exemplar {ei + 1}** — "
                f"Type: {ex.get('control_type', '?')} | "
                f"Placement: {ex.get('placement', '?')} | "
                f"Quality: {ex.get('quality_rating', '?')}"
            )
            ec1, ec2, ec3 = st.columns(3)
            with ec1:
                ex["control_type"] = st.selectbox(
                    "Control Type", options=type_names or [""],
                    index=type_names.index(ex["control_type"]) if ex.get("control_type") in type_names else 0,
                    key=f"cb_ex_ct_{idx}_{ei}",
                )
            with ec2:
                ex["placement"] = st.selectbox(
                    "Placement", options=placement_names,
                    index=placement_names.index(ex["placement"]) if ex.get("placement") in placement_names else 0,
                    key=f"cb_ex_pl_{idx}_{ei}",
                )
            with ec3:
                ex["method"] = st.selectbox(
                    "Method", options=method_names,
                    index=method_names.index(ex["method"]) if ex.get("method") in method_names else 0,
                    key=f"cb_ex_mt_{idx}_{ei}",
                )
            ex["full_description"] = st.text_area(
                "Narrative (30-80 words)", value=ex.get("full_description", ""),
                key=f"cb_ex_desc_{idx}_{ei}", height=80,
            )
            wc = len(ex["full_description"].split())
            ex["word_count"] = wc
            wc_ok = "✅" if 30 <= wc <= 80 else "⚠️"
            ex["quality_rating"] = st.selectbox(
                "Quality Rating", options=quality_options,
                index=quality_options.index(ex.get("quality_rating", "Effective")) if ex.get("quality_rating") in quality_options else 1,
                key=f"cb_ex_qr_{idx}_{ei}",
            )
            col_wc, col_rm = st.columns([3, 1])
            with col_wc:
                st.caption(f"Word count: {wc} {wc_ok}")
            with col_rm:
                if st.button("🗑 Remove", key=f"cb_ex_rm_{idx}_{ei}"):
                    to_remove.append(ei)

    if to_remove:
        _push_undo()
        for i in reversed(to_remove):
            exemplars.pop(i)
        st.rerun()


# ── Step 5: Narrative & Quality ──────────────────────────────────────────────


def _render_step_narrative(form: dict[str, Any]) -> None:
    st.markdown("#### Step 5: Narrative & Quality Settings")
    st.caption("These have sensible defaults. Customize only if needed.")

    narrative = form.setdefault("narrative", {"fields": list(_DEFAULT_NARRATIVE_FIELDS), "word_count_min": 30, "word_count_max": 80})

    # Compact summary
    n_fields = len(narrative.get("fields", []))
    wc_min = narrative.get("word_count_min", 30)
    wc_max = narrative.get("word_count_max", 80)
    st.info(f"📝 {n_fields} narrative fields defined, {wc_min}-{wc_max} word range")

    with st.expander("Customize Narrative Fields", expanded=False):
        fields = narrative.setdefault("fields", list(_DEFAULT_NARRATIVE_FIELDS))
        for fi, field in enumerate(fields):
            c1, c2 = st.columns([1, 3])
            with c1:
                field["name"] = st.text_input("Field", value=field.get("name", ""), key=f"cb_nf_name_{fi}")
            with c2:
                field["definition"] = st.text_input("Definition", value=field.get("definition", ""), key=f"cb_nf_def_{fi}")

        wc1, wc2 = st.columns(2)
        with wc1:
            narrative["word_count_min"] = st.number_input("Min Words", min_value=1, max_value=500, value=wc_min, key="cb_wc_min")
        with wc2:
            narrative["word_count_max"] = st.number_input("Max Words", min_value=1, max_value=500, value=wc_max, key="cb_wc_max")

    with st.expander("Customize Quality Ratings", expanded=False):
        qr = form.get("quality_ratings", _DEFAULT_QUALITY_RATINGS)
        qr_text = st.text_area("Quality Ratings (one per line)", value="\n".join(qr), key="cb_qr", height=80)
        form["quality_ratings"] = [r.strip() for r in qr_text.split("\n") if r.strip()]

    with st.expander("Customize Placements & Methods", expanded=False):
        placements = form.get("placements", [{"name": p, "description": ""} for p in _DEFAULT_PLACEMENTS])
        pl_text = st.text_area("Placements (one per line)", value="\n".join(p["name"] if isinstance(p, dict) else str(p) for p in placements), key="cb_pl", height=60)
        form["placements"] = [{"name": n.strip(), "description": ""} for n in pl_text.split("\n") if n.strip()]

        methods = form.get("methods", [{"name": m, "description": ""} for m in _DEFAULT_METHODS])
        mt_text = st.text_area("Methods (one per line)", value="\n".join(m["name"] if isinstance(m, dict) else str(m) for m in methods), key="cb_mt", height=60)
        form["methods"] = [{"name": n.strip(), "description": ""} for n in mt_text.split("\n") if n.strip()]

    with st.expander("Customize Frequency Tiers", expanded=False):
        tiers = form.get("frequency_tiers", list(_DEFAULT_FREQUENCY_TIERS))
        tier_text = st.text_area("Tier Labels (one per line)", value="\n".join(t["label"] if isinstance(t, dict) else str(t) for t in tiers), key="cb_ft", height=80)
        new_tiers = []
        for rank, label in enumerate(tier_text.split("\n"), 1):
            label = label.strip()
            if label:
                existing = next((t for t in tiers if isinstance(t, dict) and t.get("label") == label), None)
                keywords = existing["keywords"] if existing else [label.lower()]
                new_tiers.append({"label": label, "rank": rank, "keywords": keywords})
        form["frequency_tiers"] = new_tiers

    col_back, col_next = st.columns(2)
    with col_back:
        if st.button("← Back", key="cb_step5_back"):
            _set_step(4)
            st.rerun()
    with col_next:
        if st.button("Next →", type="primary", key="cb_step5_next"):
            _set_step(6)
            st.rerun()


# ── Step 6: Review & Export ──────────────────────────────────────────────────


def _render_step_review(form: dict[str, Any]) -> DomainConfig | None:
    st.markdown("#### Step 6: Review & Export")

    # Attempt validation
    try:
        config = DomainConfig(**form)
    except Exception as e:
        st.error(f"**Validation failed:**\n\n{e}")
        st.info("Go back to the relevant step and fix the issues listed above.")
        if st.button("← Back to Edit", key="cb_step6_back_err"):
            _set_step(5)
            st.rerun()
        return None

    # Valid! Show summary
    st.success(f"**{config.name}** is valid! {len(config.control_types)} types, {len(config.business_units)} BUs, {len(config.process_areas)} sections.")

    # Config score
    from controlnexus.ui.components.config_scorer import compute_config_score, render_config_score
    score = compute_config_score(form)
    render_config_score(score)

    # Visual summary
    if config.process_areas:
        with st.expander("Risk Landscape Overview", expanded=False):
            from controlnexus.ui.components.charts import render_risk_radar_overlay
            profiles = [(f"{pa.id}: {pa.name[:20]}", pa.risk_profile.model_dump()) for pa in config.process_areas[:8]]
            render_risk_radar_overlay(profiles)

        if config.control_types:
            with st.expander("Affinity Heatmap", expanded=False):
                from controlnexus.ui.components.charts import render_affinity_heatmap
                pa_dicts = [pa.model_dump() for pa in config.process_areas]
                ct_names = [ct.name for ct in config.control_types]
                render_affinity_heatmap(pa_dicts, ct_names)

    # Config preview
    from controlnexus.ui.config_input import render_config_preview
    render_config_preview(config)

    # Export actions
    yaml_data = form.copy()
    yaml_str = yaml.dump(yaml_data, default_flow_style=False, sort_keys=False, allow_unicode=True)

    col_dl, col_use, col_save, col_activate = st.columns(4)
    with col_dl:
        st.download_button("Download YAML", data=yaml_str, file_name=f"{config.name}.yaml", mime="text/yaml", key="cb_download")
    with col_use:
        if st.button("Use this config", key="cb_use"):
            st.session_state["wizard_active_config"] = config.model_dump()
            st.session_state["active_config"] = config.model_dump()
            st.session_state["active_config_source"] = "builder"
            st.success("Config activated!")
            return config
    with col_save:
        if st.button("Save to profiles", key="cb_save"):
            from controlnexus.ui.config_input import _profiles_dir
            out_path = _profiles_dir() / f"{config.name}.yaml"
            out_path.parent.mkdir(parents=True, exist_ok=True)
            out_path.write_text(yaml_str, encoding="utf-8")
            st.success(f"Saved to `{out_path}`")
    with col_activate:
        if st.button("Activate & Generate →", type="primary", key="cb_activate"):
            st.session_state["wizard_active_config"] = config.model_dump()
            st.session_state["active_config"] = config.model_dump()
            st.session_state["active_config_source"] = "builder"
            st.session_state["_navigate_to_tab"] = "ControlForge Modular"
            st.rerun()

    if st.button("← Back", key="cb_step6_back"):
        _set_step(5)
        st.rerun()

    # Return previously built config if available
    built = st.session_state.get("active_config")
    if built and st.session_state.get("active_config_source") == "builder":
        try:
            return DomainConfig(**built)
        except Exception:
            pass
    return None


# ── Main entry point ──────────────────────────────────────────────────────────


def render_control_builder_tab() -> None:
    """Render the Control Builder tab."""
    st.markdown('<div class="report-title">Control Builder</div>', unsafe_allow_html=True)
    st.markdown(
        '<div class="report-subtitle">Create your organization\'s control configuration</div>',
        unsafe_allow_html=True,
    )

    form = _get_form()
    current_step = _get_step()

    if current_step == 0:
        _render_starting_point(form)
        return

    # Layout: sidebar + main
    col_sidebar, col_main = st.columns([1, 4])

    with col_sidebar:
        _render_sidebar(current_step)

    with col_main:
        if current_step == 1:
            _render_step_basics(form)
        elif current_step == 2:
            _render_step_control_types(form)
        elif current_step == 3:
            _render_step_business_units(form)
        elif current_step == 4:
            _render_step_process_areas(form)
        elif current_step == 5:
            _render_step_narrative(form)
        elif current_step == 6:
            _render_step_review(form)

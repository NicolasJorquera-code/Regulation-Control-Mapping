"""Plotly chart helpers for ControlNexus UI.

Provides reusable chart functions for risk radar, affinity heatmap,
quality distribution, and section distribution.
"""

from __future__ import annotations

from typing import Any

import plotly.graph_objects as go
import streamlit as st


def render_risk_radar(
    risk_profile: dict[str, Any],
    title: str = "",
    height: int = 300,
) -> None:
    """Render a risk profile as a plotly polar chart."""
    categories = ["Inherent Risk", "Regulatory Intensity", "Control Density", "Multiplier"]
    values = [
        risk_profile.get("inherent_risk", 3),
        risk_profile.get("regulatory_intensity", 3),
        risk_profile.get("control_density", 3),
        risk_profile.get("multiplier", 1.0),
    ]
    # Close the polygon
    values.append(values[0])
    categories.append(categories[0])

    fig = go.Figure(
        data=go.Scatterpolar(
            r=values,
            theta=categories,
            fill="toself",
            fillcolor="rgba(15, 98, 254, 0.15)",
            line=dict(color="#0f62fe", width=2),
        )
    )
    fig.update_layout(
        polar=dict(radialaxis=dict(visible=True, range=[0, 5])),
        showlegend=False,
        title=title,
        height=height,
        margin=dict(l=40, r=40, t=40, b=40),
    )
    st.plotly_chart(fig, use_container_width=True)


def render_risk_radar_overlay(
    profiles: list[tuple[str, dict[str, Any]]],
    height: int = 400,
) -> None:
    """Overlay multiple risk profiles on one polar chart."""
    categories = ["Inherent Risk", "Regulatory Intensity", "Control Density", "Multiplier"]
    colors = ["#0f62fe", "#da1e28", "#24a148", "#8a3ffc", "#009d9a", "#d02670"]

    fig = go.Figure()
    for idx, (label, rp) in enumerate(profiles):
        values = [
            rp.get("inherent_risk", 3),
            rp.get("regulatory_intensity", 3),
            rp.get("control_density", 3),
            rp.get("multiplier", 1.0),
        ]
        values.append(values[0])
        color = colors[idx % len(colors)]
        fig.add_trace(
            go.Scatterpolar(
                r=values,
                theta=categories + [categories[0]],
                fill="toself",
                fillcolor=f"rgba({int(color[1:3], 16)},{int(color[3:5], 16)},{int(color[5:7], 16)},0.1)",
                line=dict(color=color, width=2),
                name=label,
            )
        )

    fig.update_layout(
        polar=dict(radialaxis=dict(visible=True, range=[0, 5])),
        showlegend=True,
        height=height,
        margin=dict(l=40, r=40, t=40, b=40),
    )
    st.plotly_chart(fig, use_container_width=True)


def render_affinity_heatmap(
    process_areas: list[dict[str, Any]],
    control_type_names: list[str],
) -> None:
    """Render sections x types heatmap colored by affinity level."""
    level_map = {"HIGH": 3, "MEDIUM": 2, "LOW": 1, "NONE": 0}
    section_labels = [f"{pa.get('id', '?')}: {pa.get('name', '?')[:20]}" for pa in process_areas]

    z: list[list[int]] = []
    for pa in process_areas:
        affinity = pa.get("affinity", {})
        row: list[int] = []
        # Build reverse lookup
        type_level: dict[str, str] = {}
        for level in ("HIGH", "MEDIUM", "LOW", "NONE"):
            for t in affinity.get(level, []):
                type_level[t] = level
        for ct_name in control_type_names:
            row.append(level_map.get(type_level.get(ct_name, "NONE"), 0))
        z.append(row)

    fig = go.Figure(
        data=go.Heatmap(
            z=z,
            x=control_type_names,
            y=section_labels,
            colorscale=[
                [0.0, "#f4f4f4"],
                [0.33, "#e0e0e0"],
                [0.66, "#f1c21b"],
                [1.0, "#24a148"],
            ],
            zmin=0,
            zmax=3,
            showscale=False,
        )
    )
    fig.update_layout(
        height=max(200, len(process_areas) * 40),
        margin=dict(l=10, r=10, t=10, b=10),
        xaxis=dict(tickangle=45),
    )
    st.plotly_chart(fig, use_container_width=True)


def _to_dict(obj: Any) -> dict[str, Any]:
    """Convert a Pydantic model or dict to a plain dict."""
    if hasattr(obj, "model_dump"):
        return obj.model_dump()
    return obj


def render_risk_heatmap(process_areas: list[Any]) -> None:
    """Risk heatmap: rows=sections, cols=risk dimensions, values 1-5."""
    process_areas = [_to_dict(pa) for pa in process_areas]
    dimensions = ["inherent_risk", "regulatory_intensity", "control_density"]
    dim_labels = ["Inherent Risk", "Regulatory Intensity", "Control Density"]
    section_labels = [f"{pa.get('id', '?')}: {pa.get('name', '?')[:20]}" for pa in process_areas]

    z = []
    for pa in process_areas:
        rp = pa.get("risk_profile", {})
        z.append([rp.get(d, 3) for d in dimensions])

    fig = go.Figure(
        data=go.Heatmap(
            z=z,
            x=dim_labels,
            y=section_labels,
            colorscale="YlOrRd",
            zmin=1,
            zmax=5,
        )
    )
    fig.update_layout(
        height=max(200, len(process_areas) * 40),
        margin=dict(l=10, r=10, t=10, b=10),
    )
    st.plotly_chart(fig, use_container_width=True)


def render_affinity_distribution(process_areas: list[Any]) -> None:
    """Stacked horizontal bar: per section, count of HIGH/MEDIUM/LOW/NONE."""
    process_areas = [_to_dict(pa) for pa in process_areas]
    section_labels = [f"{pa.get('id', '?')}: {pa.get('name', '?')[:20]}" for pa in process_areas]
    levels = ["HIGH", "MEDIUM", "LOW", "NONE"]
    colors = {"HIGH": "#24a148", "MEDIUM": "#f1c21b", "LOW": "#e0e0e0", "NONE": "#f4f4f4"}

    fig = go.Figure()
    for level in levels:
        counts = [len(pa.get("affinity", {}).get(level, [])) for pa in process_areas]
        fig.add_trace(
            go.Bar(
                y=section_labels,
                x=counts,
                name=level,
                orientation="h",
                marker_color=colors[level],
            )
        )

    fig.update_layout(
        barmode="stack",
        height=max(200, len(process_areas) * 35),
        margin=dict(l=10, r=10, t=10, b=10),
        legend=dict(orientation="h", yanchor="bottom", y=1.02, xanchor="right", x=1),
    )
    st.plotly_chart(fig, use_container_width=True)


def render_quality_distribution(records: list[dict[str, Any]]) -> None:
    """Donut chart of quality ratings from generated controls."""
    from collections import Counter

    ratings = Counter(r.get("quality_rating", "Unknown") for r in records)
    labels = list(ratings.keys())
    values = list(ratings.values())
    colors = {
        "Strong": "#24a148",
        "Effective": "#0f62fe",
        "Satisfactory": "#f1c21b",
        "Needs Improvement": "#da1e28",
    }

    fig = go.Figure(
        data=go.Pie(
            labels=labels,
            values=values,
            hole=0.5,
            marker=dict(colors=[colors.get(l, "#a8a8a8") for l in labels]),
        )
    )
    fig.update_layout(height=300, margin=dict(l=10, r=10, t=10, b=10))
    st.plotly_chart(fig, use_container_width=True)


def render_section_distribution(records: list[dict[str, Any]]) -> None:
    """Bar chart of controls per section from generated controls."""
    from collections import Counter

    sections = Counter(r.get("selected_level_1", "Unknown") for r in records)
    labels = list(sections.keys())
    values = list(sections.values())

    fig = go.Figure(data=go.Bar(x=labels, y=values, marker_color="#0f62fe"))
    fig.update_layout(
        height=300,
        margin=dict(l=10, r=10, t=10, b=10),
        xaxis_title="Section",
        yaxis_title="Controls",
    )
    st.plotly_chart(fig, use_container_width=True)


def render_type_section_heatmap(records: list[dict[str, Any]]) -> None:
    """Type x Section heatmap showing control counts."""
    from collections import Counter

    pairs = Counter((r.get("selected_level_2", "?"), r.get("selected_level_1", "?")) for r in records)
    types = sorted({p[0] for p in pairs})
    sections = sorted({p[1] for p in pairs})

    z = [[pairs.get((t, s), 0) for t in types] for s in sections]

    fig = go.Figure(
        data=go.Heatmap(z=z, x=types, y=sections, colorscale="Blues")
    )
    fig.update_layout(
        height=max(200, len(sections) * 40),
        margin=dict(l=10, r=10, t=10, b=10),
        xaxis=dict(tickangle=45),
    )
    st.plotly_chart(fig, use_container_width=True)

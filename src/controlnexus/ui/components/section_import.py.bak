"""Section YAML import dialog for Control Builder."""

from __future__ import annotations

import logging
from pathlib import Path
from typing import Any

import streamlit as st
import yaml

logger = logging.getLogger(__name__)


def _sections_dir() -> Path:
    """Resolve the config/sections directory."""
    candidates = [
        Path.cwd() / "config" / "sections",
        Path(__file__).resolve().parents[4] / "config" / "sections",
    ]
    for c in candidates:
        if c.is_dir():
            return c
    return candidates[0]


def _load_section_yaml(path: Path) -> dict[str, Any] | None:
    """Load a section YAML file."""
    try:
        data = yaml.safe_load(path.read_text(encoding="utf-8"))
        if not isinstance(data, dict):
            return None
        return data
    except Exception:
        logger.debug("Failed to load section YAML %s", path)
        return None


def render_section_import(
    existing_section_ids: list[str],
    key_prefix: str = "sec_import",
) -> list[dict[str, Any]]:
    """Render a section import dialog.

    Lists available section YAML files from config/sections/,
    lets the user multiselect which to import, and returns
    the selected sections as dicts ready to append to the form's
    process_areas list.

    Returns empty list if nothing selected or import cancelled.
    """
    sections_path = _sections_dir()
    yaml_files = sorted(sections_path.glob("section_*.yaml")) if sections_path.is_dir() else []

    if not yaml_files:
        st.info("No section YAML files found in `config/sections/`.")
        return []

    # Load all available sections
    available: list[dict[str, Any]] = []
    for yf in yaml_files:
        data = _load_section_yaml(yf)
        if data:
            sid = data.get("section_id", yf.stem)
            domain = data.get("domain", "")
            name = domain.replace("_", " ").title() if domain else yf.stem
            available.append({
                "file": yf.name,
                "section_id": sid,
                "name": name,
                "domain": domain,
                "data": data,
                "already_imported": sid in existing_section_ids,
            })

    # Show available sections
    options = [
        f"{s['section_id']}: {s['name']}" + (" (already imported)" if s["already_imported"] else "")
        for s in available
    ]
    selected = st.multiselect(
        "Select sections to import",
        options=options,
        key=f"{key_prefix}_select",
    )

    if not selected:
        return []

    if not st.button("📥 Import Selected", key=f"{key_prefix}_btn", type="primary"):
        return []

    # Convert selected to process_area dicts
    imported: list[dict[str, Any]] = []
    for sel_label in selected:
        idx = options.index(sel_label)
        sec = available[idx]
        data = sec["data"]

        pa = {
            "id": data.get("section_id", sec["section_id"]),
            "name": sec["name"],
            "domain": data.get("domain", ""),
            "risk_profile": data.get("risk_profile", {
                "inherent_risk": 3,
                "regulatory_intensity": 3,
                "control_density": 3,
                "multiplier": 1.0,
                "rationale": "",
            }),
            "affinity": data.get("affinity", {"HIGH": [], "MEDIUM": [], "LOW": [], "NONE": []}),
            "registry": data.get("registry", {
                "roles": [],
                "systems": [],
                "data_objects": [],
                "evidence_artifacts": [],
                "event_triggers": [],
                "regulatory_frameworks": [],
            }),
            "exemplars": data.get("exemplars", []),
        }
        imported.append(pa)

    return imported
